VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_AUTH_METHOD=token
VAULT_DB_DYNAMIC_ENABLED=true
VAULT_DB_MOUNT=database

POSTGRES_DB=appdb
POSTGRES_USER=vaultadmin
POSTGRES_PASSWORD=vaultadminsecret

REDIS_PASSWORD=redissecret

RABBITMQ_DEFAULT_USER=appuser
RABBITMQ_DEFAULT_PASS=rabbitsecret
RABBITMQ_DEFAULT_VHOST=/

DB_HOST=postgres
DB_PORT=5432
DB_NAME=appdb
DB_POOL_MAX=10
DB_POOL_DRAIN_MS=5000

VAULT_TIMEOUT_MS=5000
VAULT_RETRY_LIMIT=5
VAULT_RETRY_BASE_DELAY_MS=250
VAULT_RETRY_MAX_DELAY_MS=5000
VAULT_CIRCUIT_FAILURE_THRESHOLD=5
VAULT_CIRCUIT_RESET_AFTER_MS=10000
VAULT_DB_LEASE_RENEW_INCREMENT_SECONDS=60
VAULT_DB_ROTATE_BEFORE_EXPIRY_SECONDS=10
VAULT_DB_ROTATION_RETRY_MS=5000

PRODUCT_SERVICE_URL=http://product-service:3001
CUSTOMER_SERVICE_URL=http://customer-service:3002
INVENTORY_SERVICE_URL=http://inventory-service:3003
ORDER_SERVICE_URL=http://order-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005

MONGO_ROOT_USERNAME=mongo_root
MONGO_ROOT_PASSWORD=mongo_root_password
MONGO_DYNAMIC_ENABLED=true
MONGO_VERSION=7.0
MONGO_VAULT_DB_MOUNT=database
MONGO_VAULT_DB_CONFIG=mongo70
MONGO_VAULT_DB_ROLE=mongo70-product-role
MONGO_HOST=mongo70
MONGO_PORT=27017
MONGO_DATABASE=appdb
MONGO_AUTH_SOURCE=admin
